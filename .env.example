# Qwen 后端代理地址（本地开发默认 http://localhost:8787）
# 部署到生产时换成实际域名
VITE_QWEN_PROXY_URL="http://localhost:8787"

# ============ Supabase（可选 · 不配置则降级为纯 localStorage 模式） ============
# 1. 在 https://supabase.com 创建项目
# 2. Dashboard → SQL Editor → 执行 supabase/schema.sql
# 3. Dashboard → Authentication → Providers → Anonymous → 开启
# 4. Dashboard → Settings → API → 复制 Project URL 和 anon key 填入下方
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
